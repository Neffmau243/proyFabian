# --- AprendeIA - Configuracion ---
# Copia este archivo como .env y completa tus valores.

# --- Gemini API ---
# Obten tu API key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=TU_CLAVE_AQUI
GEMINI_MODEL=gemini-2.0-flash

# --- MySQL ---
# Crea la base de datos primero:
#   mysql -u root -p < src/migrations/001_schema.sql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_contraseña_mysql
DB_NAME=aprendeia

# --- JWT (opcional) ---
# JWT_SECRET=mi_clave_secreta_super_segura

# --- Puerto del servidor (opcional) ---
# PORT=3000
